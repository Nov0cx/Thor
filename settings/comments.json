{
    "odin":       { "line": "//", "extensions": [".odin"] },
    "c":          { "line": "//", "extensions": [".c", ".h"] },
    "cpp":        { "line": "//", "extensions": [".cpp", ".cc", ".cxx", ".c++", ".hpp", ".hh", ".hxx", ".h++", ".ipp"] },
    "rust":       { "line": "//", "extensions": [".rs"] },
    "go":         { "line": "//", "extensions": [".go"] },
    "javascript": { "line": "//", "extensions": [".js", ".jsx", ".mjs", ".cjs", ".ts", ".mts", ".cts", ".tsx"] },
    "zig":        { "line": "//", "extensions": [".zig"] },
    "glsl":       { "line": "//", "extensions": [".glsl", ".vert", ".frag"] },
    "python":     { "line": "#",  "extensions": [".py"] },
    "shell":      { "line": "#",  "extensions": [".sh"] },
    "toml":       { "line": "#",  "extensions": [".toml"] },
    "yaml":       { "line": "#",  "extensions": [".yml", ".yaml"] },
    "git":        { "line": "#",  "extensions": [".gitignore", ".gitmodules"] },
    "ini":        { "line": ";",  "extensions": [".ini", ".cfg"] },
    "batch":      { "line": "::", "extensions": [".bat"] },
    "lua":        { "line": "--", "extensions": [".lua"] },
    "jai":        { "line": "//", "extensions": [".jai"] },
    "java":       { "line": "//", "extensions": [".java"] },
    "kotlin":     { "line": "//", "extensions": [".kt"] }
}
